effect "starfield"

sprite dot {
  bitmap """
  #
  """
}

for i = 0; i < 20; i = i + 1 {
  layer s {
    use dot
    color rgb(200 + 55 * sin(t + i), 200 + 55 * cos(t + i * 0.7), 255)
    x = (i * 7 + 3) % 16
    y = (t * (3 + i % 4) + i * 11) % 32
    scale = 1
    blend = add
    visible = 1
  }
}
