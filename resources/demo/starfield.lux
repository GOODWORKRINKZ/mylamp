effect "starfield"

sprite dot {
  bitmap """
  #
  """
}

for j = 0; j < 20; j = j + 1 {
  layer s {
    use dot
    color rgb(200 + 55 * sin(t + j), 200 + 55 * cos(t + j * 0.7), 255)
    x = (j * 7 + 3) % 16
    y = (t * (3 + j % 4) + j * 11) % 32
    scale = 1
    blend = add
    visible = 1
  }
}
